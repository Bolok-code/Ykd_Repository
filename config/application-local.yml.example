# 本地开发配置文件模板
# 复制此文件为 application-local.yml，填入真实密钥
# cp config/application-local.yml.example config/application-local.yml

spring:
  datasource:
    url: jdbc:mysql://127.0.0.1:3306/ykd_bot?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=UTF-8
    username: root
    password: your-mysql-password
  ai:
    openai:
      api-key: sk-your-openai-api-key
    deepseek:
      api-key: sk-your-deepseek-api-key
    elevenlabs:
      api-key: sk-your-elevenlabs-api-key

gaode:
  key: your-gaode-api-key
web-search:
  enabled: ${WEB_SEARCH_ENABLED:false}
  api-key: ${VOLCENGINE_SEARCH_API_KEY:}
  endpoint: ${VOLCENGINE_SEARCH_ENDPOINT:}
  max-results: ${WEB_SEARCH_MAX_RESULTS:5}
  timeout-seconds: ${WEB_SEARCH_TIMEOUT_SECONDS:15}